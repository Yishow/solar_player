# Solar Display — Environment Configuration
# Copy this file to .env and fill in actual values.

# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# Database (SQLite)
DATA_DIR=./data
DATABASE_PATH=./data/solar-display.sqlite
# Background metric history retention
# Retain metric_snapshots for 90 days by default.
METRIC_SNAPSHOT_RETENTION_DAYS=90
# Retain daily_energy_summaries for 1825 days (5 years) by default.
DAILY_SUMMARY_RETENTION_DAYS=1825
# Set to false to skip periodic VACUUM after retention sweeps.
METRIC_RETENTION_VACUUM_ENABLED=true

# MQTT (optional — set data_mode=mqtt to enable)
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=solar-display
MQTT_DATA_MODE=mock

# Logging
LOG_DIR=./logs
LOG_LEVEL=info

# Management access boundary
MANAGEMENT_TRUSTED_ORIGINS=
MANAGEMENT_ACCESS_TOKEN=

# Kiosk exit helper (Device Status "exit kiosk" action)
# KIOSK_USER selects the installed helper at /home/<user>/bin/stop-solar-kiosk.sh (default pi).
KIOSK_USER=pi
# KIOSK_EXIT_HELPER_PATH overrides the helper path entirely when set.
KIOSK_EXIT_HELPER_PATH=
# KIOSK_EXIT_DELAY_MS delays the helper so the HTTP response is sent first (default 750).
KIOSK_EXIT_DELAY_MS=750

# CWA Weather (optional)
CWA_AUTHORIZATION=
CWA_OPEN_DATA_URL=https://opendata.cwa.gov.tw/api/v1/rest/datastore/O-A0001-001
WEATHER_REQUEST_TIMEOUT_MS=5000

# Frontend (Vite)
# VITE_API_BASE_URL is for production/preview deployments that need an explicit API origin.
# Leave it empty during local dev; Vite proxies /api, /socket.io, and /uploads to PORT.
VITE_API_BASE_URL=
# Comma-separated management routes hidden from operator navigation and redirected
# away when entered directly in the browser. This is a frontend UX control only and
# does not restrict the backend APIs. Set to an empty value to show all management routes.
VITE_HIDDEN_MANAGEMENT_ROUTES=/trends,/history
# VITE_PORT controls only where the Vite web server listens.
VITE_PORT=5173
